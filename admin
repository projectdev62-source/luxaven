  document.getElementById('imgPreviewGrid').innerHTML = '';

  if (id) {
    const v = VEHICLES.find(x => x.id === id);
    if (!v) return;
    document.getElementById('vehicleModalTitle').textContent = 'Modifier le véhicule';
    document.getElementById('v-id').value = v.id;
    document.getElementById('v-name').value = v.name;
    document.getElementById('v-year').value = v.year;
    document.getElementById('v-price').value = v.price_per_day;
    document.getElementById('v-category').value = v.category;
    document.getElementById('v-status').value = v.status;
    document.getElementById('v-fuel').value = v.fuel;
    document.getElementById('v-trans').value = v.transmission;
    document.getElementById('v-seats').value = v.seats;
    document.getElementById('v-desc').value = v.description || '';
    document.getElementById('v-homepage').checked = v.show_on_homepage;
    // load existing images as "already uploaded"
    pendingImages = (v.images || []).map(url => ({ url, existing: true }));
    renderImagePreviews();
  } else {
    document.getElementById('vehicleModalTitle').textContent = 'Ajouter un véhicule';
  }
  document.getElementById('vehicleModal').classList.add('open');
}

function closeVehicleModal(){
  document.getElementById('vehicleModal').classList.remove('open');
}

/* ═══════════ IMAGE UPLOAD (WebP conversion) ═══════════ */
document.getElementById('imgFileInput').addEventListener('change', async (e) => {
  const files = Array.from(e.target.files);
  for (const file of files) {
    const idx = pendingImages.length;
    pendingImages.push({ uploading: true, file });
    renderImagePreviews();
    try {
      const webpBlob = await convertToWebP(file);
      const previewUrl = URL.createObjectURL(webpBlob);
      pendingImages[idx] = { blob: webpBlob, previewUrl, uploading: false };
    } catch(err) {
      showToast('Erreur conversion image', 'error');
      pendingImages.splice(idx, 1);
    }
    renderImagePreviews();
  }
  e.target.value = '';
});

function convertToWebP(file, maxWidth=1200, quality=0.8){
  return new Promise((resolve, reject) => {
    const img = new Image();
    const reader = new FileReader();
    reader.onload = (e) => { img.src = e.target.result; };
    reader.onerror = reject;
    img.onload = () => {
      let w = img.width, h = img.height;
      if (w > maxWidth) { h = h * (maxWidth / w); w = maxWidth; }
      const canvas = document.createElement('canvas');
      canvas.width = w; canvas.height = h;
      const ctx = canvas.getContext('2d');
      ctx.drawImage(img, 0, 0, w, h);
      canvas.toBlob((blob) => {
        if (blob) resolve(blob); else reject(new Error('Conversion failed'));
      }, 'image/webp', quality);
    };
    img.onerror = reject;
    reader.readAsDataURL(file);
  });
}

function renderImagePreviews(){
  const grid = document.getElementById('imgPreviewGrid');
  grid.innerHTML = pendingImages.map((img, i) => {
    if (img.uploading) {
      return `<div class="img-preview"><div class="img-uploading-overlay"><span class="spinner"></span></div></div>`;
    }
    const src = img.url || img.previewUrl;
    return `
    <div class="img-preview">
      <img src="${src}">
      <button type="button" class="img-preview-remove" onclick="removePendingImage(${i})">×</button>
    </div>`;
  }).join('');
}

function removePendingImage(i){
  pendingImages.splice(i, 1);
  renderImagePreviews();
}

/* ═══════════ SAVE VEHICLE ═══════════ */
async function saveVehicle(){
  const id = document.getElementById('v-id').value;
  const name = document.getElementById('v-name').value.trim();
  const year = parseInt(document.getElementById('v-year').value);
  const price = parseInt(document.getElementById('v-price').value);
  const category = document.getElementById('v-category').value;
  const status = document.getElementById('v-status').value;
  const fuel = document.getElementById('v-fuel').value;
  const trans = document.getElementById('v-trans').value;
  const seats = parseInt(document.getElementById('v-seats').value);
  const desc = document.getElementById('v-desc').value.trim();
  const homepage = document.getElementById('v-homepage').checked;

  if (!name || !year || !price) {
    showToast('Veuillez remplir tous les champs obligatoires', 'error');
    return;
  }

  const btn = document.getElementById('saveVehicleBtn');
  btn.disabled = true;
  btn.innerHTML = '<span class="spinner"></span> Enregistrement...';

  try {
    // Upload new images (those with .blob), keep existing (.url)
    const finalImageUrls = [];
    for (const img of pendingImages) {
      if (img.url) {
        finalImageUrls.push(img.url);
      } else if (img.blob) {
        const fileName = `${Date.now()}-${Math.random().toString(36).slice(2,8)}.webp`;
        const { data, error } = await sb.storage
          .from('vehicle-images')
          .upload(fileName, img.blob, { contentType: 'image/webp' });
        if (error) throw error;
        const { data: pub } = sb.storage.from('vehicle-images').getPublicUrl(fileName);
        finalImageUrls.push(pub.publicUrl);
      }
    }

    const payload = {
      name, year, category, status, fuel,
      transmission: trans, seats,
      price_per_day: price,
      description: desc,
      show_on_homepage: homepage,
      images: finalImageUrls
    };

    if (id) {
      const { error } = await sb.from('vehicles').update(payload).eq('id', id);
      if (error) throw error;
      showToast('Véhicule modifié avec succès');
    } else {
      const { error } = await sb.from('vehicles').insert(payload);
      if (error) throw error;
      showToast('Véhicule ajouté avec succès');
    }

    closeVehicleModal();
    loadVehicles();
  } catch(err) {
    console.error(err);
    showToast('Erreur: ' + (err.message || 'échec de l\'enregistrement'), 'error');
  } finally {
    btn.disabled = false;
    btn.innerHTML = 'Enregistrer';
  }
}

/* ═══════════ DELETE VEHICLE ═══════════ */
async function deleteVehicle(id){
  const v = VEHICLES.find(x => x.id === id);
  if (!v) return;
  if (!confirm(`Supprimer "${v.name}" ? Cette action est irréversible et supprimera aussi ses photos.`)) return;

  try {
    // Delete images from storage first
    if (v.images && v.images.length) {
      const paths = v.images.map(url => url.split('/vehicle-images/')[1]).filter(Boolean);
      if (paths.length) {
        await sb.storage.from('vehicle-images').remove(paths);
      }
    }
    const { error } = await sb.from('vehicles').delete().eq('id', id);
    if (error) throw error;
    showToast('Véhicule supprimé');
    loadVehicles();
  } catch(err) {
    console.error(err);
    showToast('Erreur lors de la suppression', 'error');
  }
}

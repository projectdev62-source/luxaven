<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Luxaven — Admin</title>
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<style>
  :root{
    --black:#080808; --g1:#111; --g2:#1a1a1a; --g3:#222; --g4:#2c2c2c;
    --g5:#666; --g6:#999; --white:#f5f4f0; --red:#C0392B; --green:#2ecc71;
  }
  *{margin:0;padding:0;box-sizing:border-box}
  body{
    background:var(--black); color:var(--white);
    font-family:'DM Sans',Arial,sans-serif;
    min-height:100vh;
  }
  ::-webkit-scrollbar{width:8px}
  ::-webkit-scrollbar-track{background:var(--g1)}
  ::-webkit-scrollbar-thumb{background:var(--g4);border-radius:4px}

  /* ── LOGIN ── */
  #loginScreen{
    min-height:100vh;display:flex;align-items:center;justify-content:center;
    padding:20px;
  }
  .login-box{
    width:100%;max-width:380px;
    background:var(--g1);border:1px solid var(--g3);
    padding:40px 32px;border-radius:4px;
  }
  .login-logo{text-align:center;margin-bottom:32px}
  .login-logo img{height:50px;filter:brightness(0) invert(1)}
  .login-title{font-size:18px;font-weight:500;text-align:center;margin-bottom:6px}
  .login-sub{font-size:12px;color:var(--g5);text-align:center;margin-bottom:28px}
  .form-group{margin-bottom:16px}
  .form-label{font-size:11px;letter-spacing:1px;text-transform:uppercase;color:var(--g6);display:block;margin-bottom:6px}
  .form-input, .form-select, .form-textarea{
    width:100%;background:var(--g2);border:1px solid var(--g3);
    color:var(--white);padding:11px 14px;font-size:14px;border-radius:3px;
    font-family:inherit;
  }
  .form-input:focus, .form-select:focus, .form-textarea:focus{
    outline:none;border-color:var(--red);
  }
  .form-textarea{resize:vertical;min-height:80px}
  .btn{
    display:inline-flex;align-items:center;justify-content:center;gap:8px;
    padding:11px 22px;font-size:13px;font-weight:500;
    border-radius:3px;cursor:pointer;border:none;
    font-family:inherit;transition:opacity .2s,background .2s;
  }
  .btn:hover{opacity:0.88}
  .btn-block{width:100%}
  .btn-red{background:var(--red);color:#fff}
  .btn-white{background:var(--white);color:#000}
  .btn-ghost{background:transparent;color:var(--white);border:1px solid var(--g4)}
  .btn-ghost:hover{background:var(--g2);opacity:1}
  .btn-sm{padding:7px 14px;font-size:12px}
  .login-error{
    background:rgba(192,57,43,0.12);border:1px solid rgba(192,57,43,0.3);
    color:#e74c3c;font-size:12px;padding:10px 12px;border-radius:3px;
    margin-bottom:16px;display:none;
  }

  /* ── APP SHELL ── */
  #appShell{display:none;min-height:100vh}
  .topbar{
    height:64px;border-bottom:1px solid var(--g2);
    display:flex;align-items:center;justify-content:space-between;
    padding:0 24px;position:sticky;top:0;background:var(--black);z-index:50;
  }
  .topbar-logo{display:flex;align-items:center;gap:10px}
  .topbar-logo img{height:30px;filter:brightness(0) invert(1)}
  .topbar-right{display:flex;align-items:center;gap:14px}
  .admin-email{font-size:12px;color:var(--g6)}

  .layout{display:flex;min-height:calc(100vh - 64px)}
  .sidebar{
    width:220px;border-right:1px solid var(--g2);
    padding:24px 0;flex-shrink:0;
  }
  .nav-item{
    display:flex;align-items:center;gap:12px;
    padding:12px 24px;font-size:13px;color:var(--g6);
    cursor:pointer;transition:background .2s,color .2s;
    border-left:2px solid transparent;
  }
  .nav-item:hover{color:var(--white);background:var(--g1)}
  .nav-item.active{color:var(--white);background:var(--g1);border-left-color:var(--red)}
  .nav-badge{
    margin-left:auto;background:var(--red);color:#fff;
    font-size:10px;font-weight:600;padding:2px 7px;border-radius:10px;
    min-width:18px;text-align:center;
  }

  .main{flex:1;padding:32px;overflow-x:auto}
  .page-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:28px;flex-wrap:wrap;gap:12px}
  .page-title{font-size:24px;font-weight:500}
  .page-sub{font-size:12px;color:var(--g5);margin-top:4px}

  /* ── VEHICLES TABLE ── */
  .v-grid{
    display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));
    gap:16px;
  }
  .v-card{
    background:var(--g1);border:1px solid var(--g2);border-radius:4px;
    overflow:hidden;
  }
  .v-card-img{
    height:150px;background:var(--g2);position:relative;overflow:hidden;
  }
  .v-card-img img{width:100%;height:100%;object-fit:cover}
  .v-card-badges{position:absolute;top:10px;left:10px;right:10px;display:flex;justify-content:space-between}
  .badge{
    font-size:10px;font-weight:600;letter-spacing:0.5px;text-transform:uppercase;
    padding:4px 8px;border-radius:3px;
  }
  .badge-avail{background:rgba(46,204,113,0.15);color:#2ecc71}
  .badge-rented{background:rgba(192,57,43,0.15);color:#e74c3c}
  .badge-home{background:rgba(255,255,255,0.1);color:#fff}
  .v-card-body{padding:14px}
  .v-card-name{font-size:15px;font-weight:500;margin-bottom:4px}
  .v-card-meta{font-size:11px;color:var(--g5);margin-bottom:10px}
  .v-card-price{font-size:13px;font-weight:600;color:var(--white);margin-bottom:12px}
  .v-card-actions{display:flex;gap:8px}
  .v-card-actions .btn{flex:1}

  .empty-state{
    text-align:center;padding:60px 20px;color:var(--g5);
    border:1px dashed var(--g3);border-radius:4px;
  }

  /* ── MODAL ── */
  .modal-overlay{
    display:none;position:fixed;inset:0;background:rgba(0,0,0,0.7);
    z-index:200;align-items:center;justify-content:center;padding:20px;
    overflow-y:auto;
  }
  .modal-overlay.open{display:flex}
  .modal-box{
    background:var(--g1);border:1px solid var(--g3);border-radius:6px;
    width:100%;max-width:560px;max-height:90vh;overflow-y:auto;
    margin:auto;
  }
  .modal-header{
    padding:20px 24px;border-bottom:1px solid var(--g2);
    display:flex;align-items:center;justify-content:space-between;
  }
  .modal-title{font-size:16px;font-weight:500}
  .modal-close{cursor:pointer;font-size:20px;color:var(--g5);background:none;border:none}
  .modal-close:hover{color:var(--white)}
  .modal-body{padding:24px}
  .modal-footer{
    padding:16px 24px;border-top:1px solid var(--g2);
    display:flex;justify-content:flex-end;gap:10px;
  }
  .form-row{display:grid;grid-template-columns:1fr 1fr;gap:12px}
  .toggle-row{display:flex;align-items:center;justify-content:space-between;
    padding:10px 0;border-bottom:1px solid var(--g2)}
  .toggle-label{font-size:13px}
  .switch{position:relative;width:42px;height:22px}
  .switch input{opacity:0;width:0;height:0}
  .slider{
    position:absolute;cursor:pointer;inset:0;background:var(--g3);
    border-radius:22px;transition:.2s;
  }
  .slider:before{
    content:'';position:absolute;height:16px;width:16px;left:3px;bottom:3px;
    background:#fff;border-radius:50%;transition:.2s;
  }
  input:checked + .slider{background:var(--green)}
  input:checked + .slider:before{transform:translateX(20px)}

  /* Image upload */
  .img-upload-zone{
    border:1px dashed var(--g3);border-radius:4px;padding:20px;
    text-align:center;cursor:pointer;transition:border-color .2s;
    font-size:12px;color:var(--g5);
  }
  .img-upload-zone:hover{border-color:var(--red)}
  .img-preview-grid{
    display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-top:12px;
  }
  .img-preview{
    position:relative;aspect-ratio:1;border-radius:3px;overflow:hidden;
    background:var(--g2);
  }
  .img-preview img{width:100%;height:100%;object-fit:cover}
  .img-preview-remove{
    position:absolute;top:4px;right:4px;width:18px;height:18px;
    background:rgba(0,0,0,0.7);border-radius:50%;display:flex;
    align-items:center;justify-content:center;cursor:pointer;font-size:11px;
    color:#fff;border:none;
  }
  .img-uploading-overlay{
    position:absolute;inset:0;background:rgba(0,0,0,0.6);
    display:flex;align-items:center;justify-content:center;font-size:10px;
  }

  /* Toast */
  #toastContainer{
    position:fixed;bottom:24px;right:24px;z-index:300;
    display:flex;flex-direction:column;gap:10px;
  }
  .toast{
    background:var(--g1);border:1px solid var(--g3);border-left:3px solid var(--green);
    padding:12px 18px;border-radius:4px;font-size:13px;
    min-width:240px;box-shadow:0 8px 24px rgba(0,0,0,0.4);
    animation:toastIn .25s ease;
  }
  .toast.error{border-left-color:var(--red)}
  @keyframes toastIn{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}

  .spinner{
    width:16px;height:16px;border:2px solid rgba(255,255,255,0.2);
    border-top-color:#fff;border-radius:50%;
    animation:spin .6s linear infinite;display:inline-block;
  }
  @keyframes spin{to{transform:rotate(360deg)}}

  /* ── RESERVATIONS ── */
  .r-list{display:flex;flex-direction:column;gap:10px}
  .r-row{
    background:var(--g1);border:1px solid var(--g3);border-radius:4px;
    padding:16px 18px;display:flex;align-items:center;gap:16px;cursor:pointer;
    transition:border-color .15s;
  }
  .r-row:hover{border-color:var(--g4)}
  .r-row-main{flex:1;min-width:0}
  .r-row-top{display:flex;align-items:center;gap:10px;margin-bottom:4px;flex-wrap:wrap}
  .r-row-client{font-size:14px;font-weight:500}
  .r-row-veh{font-size:12px;color:var(--g6)}
  .r-row-dates{font-size:11px;color:var(--g5)}
  .badge-pending{background:rgba(241,196,15,0.15);color:#f1c40f}
  .loc-chip{display:flex;align-items:center;gap:8px;background:var(--g1);border:1px solid var(--g2);
    border-radius:20px;padding:6px 8px 6px 14px;font-size:12px;color:var(--g6)}
  .loc-chip button{background:none;border:none;color:var(--g5);cursor:pointer;font-size:14px;
    line-height:1;padding:2px 4px;border-radius:50%}
  .loc-chip button:hover{color:#e74c3c;background:rgba(192,57,43,0.15)}
  .badge-confirmed{background:rgba(46,204,113,0.15);color:#2ecc71}
  .badge-rejected{background:rgba(192,57,43,0.15);color:#e74c3c}
  .r-row-arrow{color:var(--g5);font-size:18px}
  .r-detail-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:18px}
  .r-detail-item{background:var(--g2);border-radius:4px;padding:12px}
  .r-detail-label{font-size:10px;letter-spacing:1px;text-transform:uppercase;color:var(--g5);margin-bottom:5px}
  .r-detail-value{font-size:14px;color:var(--white)}
  .r-msg-box{background:var(--g2);border-radius:4px;padding:12px;font-size:13px;color:var(--g6);margin-bottom:18px;line-height:1.5}
  .r-reject-reasons{display:flex;flex-direction:column;gap:8px;margin-bottom:14px}
  .r-reason-opt{
    background:var(--g2);border:1px solid var(--g3);border-radius:4px;padding:10px 12px;
    font-size:13px;cursor:pointer;transition:border-color .15s;
  }
  .r-reason-opt:hover{border-color:var(--g5)}
  .r-reason-opt.selected{border-color:var(--red);background:rgba(192,57,43,0.08)}

  /* ── SETTINGS ── */
  .settings-form{max-width:560px}
  .settings-section{
    background:var(--g1);border:1px solid var(--g3);border-radius:4px;
    padding:20px;margin-bottom:18px;
  }
  .settings-section-title{
    font-size:13px;font-weight:600;letter-spacing:0.5px;text-transform:uppercase;
    color:var(--g6);margin-bottom:16px;
  }
  .settings-actions{display:flex;justify-content:flex-end}

  .loading-overlay{
    text-align:center;padding:60px;color:var(--g5);font-size:13px;
  }

  @media(max-width:768px){
    .sidebar{
      position:fixed;left:-220px;top:64px;bottom:0;z-index:100;
      background:var(--black);transition:left .25s;
    }
    .sidebar.open{left:0}
    .main{padding:18px}
    .form-row{grid-template-columns:1fr}
  }
</style>
</head>
<body>

<!-- ═══════════ LOGIN SCREEN ═══════════ -->
<div id="loginScreen">
  <div class="login-box">
    <div class="login-logo"><img src="data:image/png;base64," alt="Luxaven"></div>
    <div class="login-title">Espace Administrateur</div>
    <div class="login-sub">Connectez-vous pour gérer votre flotte</div>
    <div class="login-error" id="loginError"></div>
    <form id="loginForm">
      <div class="form-group">
        <label class="form-label">Email</label>
        <input type="email" class="form-input" id="loginEmail" required autocomplete="username">
      </div>
      <div class="form-group">
        <label class="form-label">Mot de passe</label>
        <input type="password" class="form-input" id="loginPassword" required autocomplete="current-password">
      </div>
      <button type="submit" class="btn btn-red btn-block" id="loginBtn">Se connecter</button>
    </form>
  </div>
</div>

<!-- ═══════════ APP SHELL ═══════════ -->
<div id="appShell">
  <div class="topbar">
    <div class="topbar-logo">
      <img src="data:image/png;base64," alt="Luxaven">
    </div>
    <div class="topbar-right">
      <span class="admin-email" id="adminEmail"></span>
      <button class="btn btn-ghost btn-sm" onclick="handleLogout()">Déconnexion</button>
    </div>
  </div>

  <div class="layout">
    <div class="sidebar">
      <div class="nav-item active" data-page="vehicles" onclick="switchPage('vehicles')">
        Catalogue
      </div>
      <div class="nav-item" data-page="reservations" onclick="switchPage('reservations')">
        Réservations
        <span class="nav-badge" id="pendingBadge" style="display:none">0</span>
      </div>
      <div class="nav-item" data-page="clients" onclick="switchPage('clients')">
        Clients
      </div>
      <div class="nav-item" data-page="settings" onclick="switchPage('settings')">
        Paramètres
      </div>
    </div>

    <div class="main">

      <!-- ── VEHICLES PAGE ── -->
      <div id="page-vehicles">
        <div class="page-header">
          <div>
            <div class="page-title">Catalogue</div>
            <div class="page-sub" id="vehicleCount">Chargement...</div>
          </div>
          <button class="btn btn-red" onclick="openVehicleModal()">+ Ajouter un véhicule</button>
        </div>
        <div id="vehiclesContainer" class="v-grid"></div>
      </div>

      <!-- ── RESERVATIONS PAGE ── -->
      <div id="page-reservations" style="display:none">
        <div class="page-header">
          <div>
            <div class="page-title">Réservations</div>
            <div class="page-sub" id="reservationCount">Chargement...</div>
          </div>
        </div>
        <div id="reservationsContainer" class="r-list"></div>
      </div>

      <!-- ── CLIENTS PAGE ── -->
      <div id="page-clients" style="display:none">
        <div class="page-header">
          <div>
            <div class="page-title">Clients</div>
            <div class="page-sub" id="clientCount">Chargement...</div>
          </div>
        </div>
        <div id="clientsContainer" class="r-list"></div>
      </div>

      <!-- ── SETTINGS PAGE (placeholder, built next step) ── -->
      <div id="page-settings" style="display:none">
        <div class="page-header">
          <div>
            <div class="page-title">Paramètres</div>
            <div class="page-sub">Coordonnées et notifications</div>
          </div>
        </div>

        <form id="settingsForm" class="settings-form">
          <div class="settings-section">
            <div class="settings-section-title">Agence</div>
            <div class="form-group">
              <label class="form-label">Nom de l'agence</label>
              <input type="text" class="form-input" id="s-agency-name" placeholder="Luxaven">
            </div>
            <div class="form-row">
              <div class="form-group">
                <label class="form-label">Téléphone agence</label>
                <input type="text" class="form-input" id="s-agency-phone" placeholder="+212 6XX XXXXXX">
              </div>
              <div class="form-group">
                <label class="form-label">Adresse</label>
                <input type="text" class="form-input" id="s-agency-address" placeholder="Rabat, Maroc">
              </div>
            </div>
          </div>

          <div class="settings-section">
            <div class="settings-section-title">WhatsApp</div>
            <div class="form-group">
              <label class="form-label">Numéro WhatsApp admin</label>
              <input type="text" class="form-input" id="s-whatsapp" placeholder="2126XXXXXXXX (sans + ni espaces)">
            </div>
          </div>

          <div class="settings-section">
            <div class="settings-section-title">Lieux de livraison</div>
            <div class="form-group" style="display:flex;gap:8px;align-items:flex-end">
              <div style="flex:1">
                <label class="form-label">Nouveau lieu</label>
                <input type="text" class="form-input" id="loc-new-name" placeholder="Ex: Gare Rabat Ville">
              </div>
              <button type="button" class="btn btn-ghost btn-sm" onclick="addLocation()">+ Ajouter</button>
            </div>
            <div id="locationsList" style="display:flex;flex-wrap:wrap;gap:8px;margin-top:12px"></div>
          </div>

          <div class="settings-section">
            <div class="settings-section-title">Notifications Telegram</div>
            <div class="form-group">
              <label class="form-label">Bot Token</label>
              <input type="text" class="form-input" id="s-telegram-token" placeholder="123456789:AAExxxxxxxxxxxxxxxxxxx">
            </div>
            <div class="form-group">
              <label class="form-label">Chat ID</label>
              <input type="text" class="form-input" id="s-telegram-chat" placeholder="123456789">
            </div>
            <button type="button" class="btn btn-ghost btn-sm" onclick="testTelegram()">Tester la notification</button>
          </div>

          <div class="settings-actions">
            <button type="submit" class="btn btn-red">Enregistrer</button>
          </div>
        </form>
      </div>

    </div>
  </div>
</div>

<!-- ═══════════ RESERVATION DETAIL MODAL ═══════════ -->
<div class="modal-overlay" id="reservationModal">
  <div class="modal-box">
    <div class="modal-header">
      <div class="modal-title">Détail réservation</div>
      <button class="modal-close" onclick="closeReservationModal()">×</button>
    </div>
    <div class="modal-body">
      <div class="r-detail-grid">
        <div class="r-detail-item">
          <div class="r-detail-label">Client</div>
          <div class="r-detail-value" id="rd-name">—</div>
        </div>
        <div class="r-detail-item">
          <div class="r-detail-label">Téléphone</div>
          <div class="r-detail-value" id="rd-phone">—</div>
        </div>
        <div class="r-detail-item">
          <div class="r-detail-label">Véhicule</div>
          <div class="r-detail-value" id="rd-vehicle">—</div>
        </div>
        <div class="r-detail-item">
          <div class="r-detail-label">Dates</div>
          <div class="r-detail-value" id="rd-dates">—</div>
        </div>
        <div class="r-detail-item">
          <div class="r-detail-label">Total estimé</div>
          <div class="r-detail-value" id="rd-total">—</div>
        </div>
        <div class="r-detail-item">
          <div class="r-detail-label">Statut</div>
          <div class="r-detail-value" id="rd-status">—</div>
        </div>
      </div>
      <div class="r-detail-label" style="margin-bottom:6px">Message du client</div>
      <div class="r-msg-box" id="rd-message">—</div>

      <div id="rd-reject-panel" style="display:none">
        <div class="r-detail-label" style="margin-bottom:8px">Raison du refus</div>
        <div class="r-reject-reasons" id="rd-reasons"></div>
        <div class="form-group">
          <textarea class="form-textarea" id="rd-custom-reason" placeholder="Ou raison personnalisée..." rows="2"></textarea>
        </div>
      </div>
    </div>
    <div class="modal-footer" id="rd-actions">
      <!-- buttons injected by JS depending on status -->
    </div>
  </div>
</div>

<!-- ═══════════ VEHICLE MODAL (add/edit) ═══════════ -->
<div class="modal-overlay" id="vehicleModal">
  <div class="modal-box">
    <div class="modal-header">
      <div class="modal-title" id="vehicleModalTitle">Ajouter un véhicule</div>
      <button class="modal-close" onclick="closeVehicleModal()">×</button>
    </div>
    <div class="modal-body">
      <form id="vehicleForm">
        <input type="hidden" id="v-id">
        <div class="form-group">
          <label class="form-label">Nom du véhicule</label>
          <input type="text" class="form-input" id="v-name" required placeholder="Ex: BMW Série 4">
        </div>
        <div class="form-row">
          <div class="form-group">
            <label class="form-label">Année</label>
            <input type="number" class="form-input" id="v-year" required placeholder="2024">
          </div>
          <div class="form-group">
            <label class="form-label">Prix / jour (MAD)</label>
            <input type="number" class="form-input" id="v-price" required placeholder="500">
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label class="form-label">Catégorie</label>
            <select class="form-select" id="v-category"></select>
          </div>

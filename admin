/* ═══════════ RESERVATIONS ═══════════ */
let RESERVATIONS = [];
const REJECT_REASONS = [
  'Véhicule indisponible pour ces dates',
  'Documents incomplets',
  'Conditions de location non remplies',
  'Réservation en double',
];

async function loadReservations(){
  const container = document.getElementById('reservationsContainer');
  container.innerHTML = '<div class="loading-overlay">Chargement des réservations...</div>';
  const { data, error } = await sb
    .from('reservations')
    .select('*, vehicles(name, price_per_day)')
    .order('created_at', { ascending: false });
  if (error) {
    showToast('Erreur chargement réservations', 'error');
    container.innerHTML = '<div class="empty-state">Erreur de chargement.</div>';
    return;
  }
  RESERVATIONS = data || [];
  document.getElementById('reservationCount').textContent =
    `${RESERVATIONS.length} réservation${RESERVATIONS.length!==1?'s':''}`;
  updatePendingBadge();
  renderReservations();
}

function updatePendingBadge(){
  const pending = RESERVATIONS.filter(r => r.status === 'pending').length;
  const badge = document.getElementById('pendingBadge');
  if (pending > 0) {
    badge.textContent = pending;
    badge.style.display = 'inline-block';
  } else {
    badge.style.display = 'none';
  }
}

function renderReservations(){
  const container = document.getElementById('reservationsContainer');
  if (RESERVATIONS.length === 0) {
    container.innerHTML = '<div class="empty-state">Aucune réservation pour le moment.</div>';
    return;
  }
  const statusLabel = { pending: 'En attente', confirmed: 'Confirmée', rejected: 'Refusée' };
  container.innerHTML = RESERVATIONS.map(r => {
    const vehName = r.vehicles ? r.vehicles.name : '—';
    return `
    <div class="r-row" onclick="openReservationModal('${r.id}')">
      <div class="r-row-main">
        <div class="r-row-top">
          <span class="r-row-client">${r.client_name}</span>
          <span class="badge badge-${r.status}">${statusLabel[r.status] || r.status}</span>
        </div>
        <div class="r-row-veh">${vehName}</div>
        <div class="r-row-dates">${formatDate(r.start_date)} → ${formatDate(r.end_date)}</div>
      </div>
      <div class="r-row-arrow">›</div>
    </div>`;
  }).join('');
}

function formatDate(d){
  if (!d) return '—';
  const date = new Date(d);
  return date.toLocaleDateString('fr-FR', { day:'2-digit', month:'short', year:'numeric' });
}

function calcDays(start, end){
  const ms = new Date(end) - new Date(start);
  return Math.max(1, Math.round(ms / 86400000));
}

let activeReservation = null;

function openReservationModal(id){
  const r = RESERVATIONS.find(x => x.id === id);
  if (!r) return;
  activeReservation = r;
  const vehName = r.vehicles ? r.vehicles.name : '—';
  const pricePerDay = r.vehicles ? r.vehicles.price_per_day : 0;
  const days = calcDays(r.start_date, r.end_date);
  const total = pricePerDay * days;

  document.getElementById('rd-name').textContent = r.client_name || '—';
  document.getElementById('rd-phone').textContent = r.client_phone || '—';
  document.getElementById('rd-vehicle').textContent = vehName;
  document.getElementById('rd-dates').textContent = `${formatDate(r.start_date)} → ${formatDate(r.end_date)} (${days}j)`;
  document.getElementById('rd-total').textContent = total ? `${total} MAD` : '—';
  const statusLabel = { pending: 'En attente', confirmed: 'Confirmée', rejected: 'Refusée' };
  document.getElementById('rd-status').textContent = statusLabel[r.status] || r.status;
  document.getElementById('rd-message').textContent = r.message || 'Aucun message.';

  const rejectPanel = document.getElementById('rd-reject-panel');
  const reasonsBox = document.getElementById('rd-reasons');
  reasonsBox.innerHTML = REJECT_REASONS.map(reason =>
    `<div class="r-reason-opt" onclick="selectReason(this,'${reason.replace(/'/g,"\\'")}')">${reason}</div>`
  ).join('');
  document.getElementById('rd-custom-reason').value = '';
  selectedReason = '';
  rejectPanel.style.display = 'none';

  const actions = document.getElementById('rd-actions');
  if (r.status === 'pending') {
    actions.innerHTML = `
      <button class="btn btn-ghost" onclick="closeReservationModal()">Fermer</button>
      <button class="btn btn-ghost" style="color:#e74c3c" onclick="showRejectPanel()">Refuser</button>
      <button class="btn btn-red" onclick="confirmReservation()">Confirmer via WhatsApp</button>
    `;
  } else {
    actions.innerHTML = `<button class="btn btn-ghost" onclick="closeReservationModal()">Fermer</button>`;
  }

  document.getElementById('reservationModal').classList.add('open');
}

function closeReservationModal(){
  document.getElementById('reservationModal').classList.remove('open');
  activeReservation = null;
}

let selectedReason = '';
function selectReason(el, reason){
  document.querySelectorAll('.r-reason-opt').forEach(o => o.classList.remove('selected'));
  el.classList.add('selected');
  selectedReason = reason;
  document.getElementById('rd-custom-reason').value = '';
}

function showRejectPanel(){
  document.getElementById('rd-reject-panel').style.display = 'block';
  document.getElementById('rd-actions').innerHTML = `
    <button class="btn btn-ghost" onclick="closeReservationModal()">Annuler</button>
    <button class="btn btn-red" onclick="rejectReservation()">Refuser via WhatsApp</button>
  `;
}

function buildWhatsAppLink(phone, message){
  const cleanPhone = (phone || '').replace(/[^0-9]/g, '');
  return `https://wa.me/${cleanPhone}?text=${encodeURIComponent(message)}`;
}

async function confirmReservation(){
  const r = activeReservation;
  if (!r) return;
  const vehName = r.vehicles ? r.vehicles.name : 'le véhicule';
  const pricePerDay = r.vehicles ? r.vehicles.price_per_day : 0;
  const days = calcDays(r.start_date, r.end_date);
  const total = pricePerDay * days;

  const { error } = await sb.from('reservations').update({ status: 'confirmed' }).eq('id', r.id);
  if (error) { showToast('Erreur mise à jour', 'error'); return; }

  const msg = `Bonjour ${r.client_name},\n\nVotre réservation chez Luxaven est confirmée.\n\nVéhicule : ${vehName}\nDu ${formatDate(r.start_date)} au ${formatDate(r.end_date)} (${days} jour${days>1?'s':''})\nTotal estimé : ${total} MAD\n\nMerci de votre confiance, à très vite !\n— Luxaven Rent a Car`;

  window.open(buildWhatsAppLink(r.client_phone, msg), '_blank');
  showToast('Réservation confirmée');
  closeReservationModal();
  loadReservations();
}

async function rejectReservation(){
  const r = activeReservation;
  if (!r) return;
  const customReason = document.getElementById('rd-custom-reason').value.trim();
  const reason = customReason || selectedReason;
  if (!reason) { showToast('Choisissez ou écrivez une raison', 'error'); return; }

  const { error } = await sb.from('reservations')
    .update({ status: 'rejected', rejection_reason: reason })
    .eq('id', r.id);
  if (error) { showToast('Erreur mise à jour', 'error'); return; }

  const vehName = r.vehicles ? r.vehicles.name : 'le véhicule';
  const msg = `Bonjour ${r.client_name},\n\nNous sommes désolés, votre réservation pour ${vehName} (${formatDate(r.start_date)} → ${formatDate(r.end_date)}) n'a pas pu être confirmée.\n\nRaison : ${reason}\n\nN'hésitez pas à nous recontacter pour une autre disponibilité.\n— Luxaven Rent a Car`;

  window.open(buildWhatsAppLink(r.client_phone, msg), '_blank');
  showToast('Réservation refusée');
  closeReservationModal();
  loadReservations();
}

/* ═══════════ CLIENTS ═══════════ */
async function loadClients(){
  const container = document.getElementById('clientsContainer');
  container.innerHTML = '<div class="loading-overlay">Chargement des clients...</div>';
  const { data, error } = await sb
    .from('reservations')
    .select('*, vehicles(name, price_per_day)')
    .eq('status', 'confirmed')
    .order('created_at', { ascending: false });
  if (error) {
    showToast('Erreur chargement clients', 'error');
    container.innerHTML = '<div class="empty-state">Erreur de chargement.</div>';
    return;
  }
  renderClients(data || []);
}

function renderClients(confirmedReservations){
  const container = document.getElementById('clientsContainer');
  const countEl = document.getElementById('clientCount');

  // Group confirmed reservations by client phone (fallback to name if no phone)
  const groups = {};
  confirmedReservations.forEach(r => {
    const key = (r.client_phone || r.client_name || 'inconnu').trim();
    if (!groups[key]) {
      groups[key] = {
        name: r.client_name || '—',
        phone: r.client_phone || '—',
        email: r.client_email || '—',
        bookings: []
      };
    }
    groups[key].bookings.push(r);
  });

  const clients = Object.values(groups);
  countEl.textContent = `${clients.length} client${clients.length!==1?'s':''}`;

  if (clients.length === 0) {
    container.innerHTML = '<div class="empty-state">Aucun client confirmé pour le moment.</div>';
    return;
  }

  container.innerHTML = clients.map(c => {
    const bookingsHtml = c.bookings.map(b => {
      const vehName = b.vehicles ? b.vehicles.name : '—';
      const days = calcDays(b.start_date, b.end_date);
      const total = b.vehicles ? b.vehicles.price_per_day * days : null;
      return `
        <div style="display:flex;justify-content:space-between;gap:12px;padding:8px 0;border-top:1px solid var(--g2);font-size:12px;color:var(--g6)">
          <span>${vehName}</span>
          <span>${formatDate(b.start_date)} → ${formatDate(b.end_date)}</span>
          <span>${total ? total+' MAD' : '—'}</span>
        </div>`;
    }).join('');
    return `
    <div class="r-row" style="cursor:default;flex-direction:column;align-items:stretch">
      <div class="r-row-top" style="margin-bottom:4px">
        <span class="r-row-client">${c.name}</span>
        <span class="badge badge-confirmed">${c.bookings.length} réservation${c.bookings.length>1?'s':''}</span>
      </div>
      <div class="r-row-veh">${c.phone} ${c.email!=='—' ? '· '+c.email : ''}</div>
      ${bookingsHtml}
    </div>`;
  }).join('');
}

